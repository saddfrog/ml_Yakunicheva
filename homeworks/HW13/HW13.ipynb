        "# Загружаем готовую модель\n",
        "pretrained_model = AutoModelForMaskedLM.from_pretrained(model_name).to(device)\n",
        "\n",
        "# Тестовые примеры\n",
        "test_texts = [\n",
        "    \"I am so [MASK] today!\",\n",
        "    \"This is [MASK], I'm very sad.\",\n",
        "    \"I'm feeling really [MASK] about this.\",\n",
        "    \"The weather is [MASK] today.\",\n",
        "    \"This movie is [MASK]!\"\n",
        "]\n",
        "\n",
        "print(\"🔮 Инференс готовой модели (Masked Language Model):\")\n",
        "print(\"=\"*60)\n",
        "\n",
        "for text in test_texts:\n",
        "    inputs = tokenizer(text, return_tensors='pt').to(device)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = pretrained_model(**inputs)\n",
        "        logits = outputs.logits\n",
        "\n",
        "    # Находим позицию [MASK]\n",
        "    mask_token_index = (inputs['input_ids'] == tokenizer.mask_token_id).nonzero(as_tuple=True)[1]\n",
        "\n",
        "    if len(mask_token_index) > 0:\n",
        "        predicted_token_id = logits[0, mask_token_index, :].argmax(axis=-1)\n",
        "        predicted_token = tokenizer.decode(predicted_token_id)\n",
        "        print(f\"Input: {text}\")\n",
        "        print(f\"Predicted: {predicted_token}\")\n",
        "        print(\"-\" * 40)\n",
        "    else:\n",
        "        print(f\"Input: {text} - No [MASK] token found\")"
      ],
